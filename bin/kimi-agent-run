#!/usr/bin/env node

import { spawn } from 'node:child_process';
import { createWriteStream } from 'node:fs';
import { tmpdir } from 'node:os';
import { join as joinPath } from 'node:path';
import { stdin as processStdin } from 'node:process';

const DEFAULT_TIMEOUT_SECONDS = 1800;
const MAX_CAPTURE_CHARS = 10 * 1024 * 1024;

function usage() {
  return `Usage:
  kimi-agent-run [options] < prompt.txt
  kimi-agent-run --prompt "task" [options]

Runs Kimi Code CLI via its official non-interactive prompt mode:
  kimi -p "<task>" --output-format stream-json

Options:
  --prompt <text>             Prompt text. If omitted, stdin is used.
  --continue                  Continue the most recent Kimi session for the cwd.
  --session <id>              Resume a specific Kimi session id.
  --model <model>             Kimi model alias for this invocation.
  --worktree[=<name>]         Ask Kimi to create a git worktree for a new session.
  --cwd <path>                Working directory for the Kimi process.
  --timeout-seconds <n>       Timeout before terminating Kimi. Default: ${DEFAULT_TIMEOUT_SECONDS}.
  --kimi-bin <path>           Kimi executable. Default: kimi.
  --dry-run                   Print the resolved Kimi command without running it.
  --tee <path>                Mirror Kimi's live stream-json to <path> as it runs.
                              Watch it with: tail -f <path>
  --live                      Like --tee but to a temp file; prints the tail command.
  --help                      Show this help.
`;
}

function parseArgs(argv) {
  const opts = {
    kimiBin: process.env.KIMI_AGENT_KIMI_BIN || 'kimi',
    timeoutSeconds: DEFAULT_TIMEOUT_SECONDS,
    prompt: undefined,
    continue: false,
    session: undefined,
    model: undefined,
    worktree: undefined,
    cwd: process.cwd(),
    dryRun: false,
    tee: undefined,
    live: false,
  };

  for (let i = 0; i < argv.length; i += 1) {
    const arg = argv[i];
    if (arg === '--help' || arg === '-h') {
      console.log(usage());
      process.exit(0);
    }
    if (arg === '--dry-run') {
      opts.dryRun = true;
      continue;
    }
    if (arg === '--continue' || arg === '-C') {
      opts.continue = true;
      continue;
    }
    if (arg === '--prompt' || arg === '-p') {
      opts.prompt = requireValue(argv, ++i, arg);
      continue;
    }
    if (arg === '--session' || arg === '-S' || arg === '-r' || arg === '--resume') {
      opts.session = requireValue(argv, ++i, arg);
      continue;
    }
    if (arg === '--model' || arg === '-m') {
      opts.model = requireValue(argv, ++i, arg);
      continue;
    }
    if (arg === '--cwd') {
      opts.cwd = requireValue(argv, ++i, arg);
      continue;
    }
    if (arg === '--kimi-bin') {
      opts.kimiBin = requireValue(argv, ++i, arg);
      continue;
    }
    if (arg === '--tee') {
      opts.tee = requireValue(argv, ++i, arg);
      continue;
    }
    if (arg === '--live') {
      opts.live = true;
      continue;
    }
    if (arg === '--timeout-seconds') {
      const raw = requireValue(argv, ++i, arg);
      const parsed = Number(raw);
      if (!Number.isFinite(parsed) || parsed <= 0) {
        throw new Error(`Invalid --timeout-seconds value: ${raw}`);
      }
      opts.timeoutSeconds = parsed;
      continue;
    }
    if (arg === '--worktree' || arg === '-w') {
      const next = argv[i + 1];
      if (next !== undefined && !next.startsWith('-')) {
        opts.worktree = next;
        i += 1;
      } else {
        opts.worktree = true;
      }
      continue;
    }
    if (arg.startsWith('--worktree=')) {
      opts.worktree = arg.slice('--worktree='.length);
      continue;
    }
    throw new Error(`Unknown argument: ${arg}`);
  }

  if (opts.continue && opts.session !== undefined) {
    throw new Error('Cannot combine --continue with --session.');
  }
  if (opts.worktree !== undefined && (opts.continue || opts.session !== undefined)) {
    throw new Error('Cannot combine --worktree with --continue or --session.');
  }
  if (opts.live && opts.tee === undefined) {
    opts.tee = joinPath(tmpdir(), `kimi-agent-${process.pid}.jsonl`);
  }
  return opts;
}

function requireValue(argv, index, flag) {
  const value = argv[index];
  if (value === undefined || value.length === 0) {
    throw new Error(`${flag} requires a value.`);
  }
  return value;
}

function readStdin() {
  return new Promise((resolve, reject) => {
    let data = '';
    processStdin.setEncoding('utf8');
    processStdin.on('data', chunk => {
      data += chunk;
    });
    processStdin.on('error', reject);
    processStdin.on('end', () => resolve(data));
  });
}

function buildKimiArgs(opts, prompt) {
  const args = [];
  if (opts.continue) args.push('--continue');
  if (opts.session !== undefined) args.push('--session', opts.session);
  if (opts.model !== undefined) args.push('--model', opts.model);
  if (opts.worktree === true) args.push('--worktree');
  if (typeof opts.worktree === 'string') args.push(`--worktree=${opts.worktree}`);
  args.push('--prompt', prompt, '--output-format', 'stream-json');
  return args;
}

function appendLimited(current, chunk) {
  if (current.length >= MAX_CAPTURE_CHARS) return current;
  const next = current + chunk;
  return next.length > MAX_CAPTURE_CHARS ? next.slice(0, MAX_CAPTURE_CHARS) : next;
}

function runProcess(command, args, opts = {}) {
  return new Promise((resolve, reject) => {
    const child = spawn(command, args, {
      cwd: opts.cwd,
      stdio: ['ignore', 'pipe', 'pipe'],
      env: process.env,
    });

    let stdout = '';
    let stderr = '';
    let timedOut = false;

    let teeStream;
    if (opts.teePath) {
      teeStream = createWriteStream(opts.teePath, { encoding: 'utf8' });
      teeStream.on('error', error => {
        process.stderr.write(`Live tee to ${opts.teePath} failed: ${error.message}\n`);
        teeStream = undefined;
      });
    }

    const timer = setTimeout(() => {
      timedOut = true;
      child.kill('SIGTERM');
      setTimeout(() => child.kill('SIGKILL'), 5000).unref();
    }, opts.timeoutSeconds * 1000);
    timer.unref();

    child.stdout.setEncoding('utf8');
    child.stderr.setEncoding('utf8');
    child.stdout.on('data', chunk => {
      stdout = appendLimited(stdout, chunk);
      if (teeStream) teeStream.write(chunk);
    });
    child.stderr.on('data', chunk => {
      stderr = appendLimited(stderr, chunk);
    });
    child.on('error', reject);
    child.on('close', (code, signal) => {
      clearTimeout(timer);
      if (teeStream) teeStream.end();
      resolve({ code, signal, stdout, stderr, timedOut });
    });
  });
}

function parseKimiStreamJson(stdout) {
  const assistant = [];
  const toolCalls = [];
  const toolResults = [];
  const parseErrors = [];
  let resumeHint = undefined;

  for (const rawLine of stdout.split(/\r?\n/)) {
    const line = rawLine.trim();
    if (line.length === 0) continue;
    let message;
    try {
      message = JSON.parse(line);
    } catch (error) {
      parseErrors.push(line);
      continue;
    }

    if (message.role === 'assistant') {
      if (typeof message.content === 'string' && message.content.trim().length > 0) {
        assistant.push(message.content.trim());
      }
      if (Array.isArray(message.tool_calls)) {
        for (const call of message.tool_calls) {
          const name = call?.function?.name;
          toolCalls.push(typeof name === 'string' && name.length > 0 ? name : '(unknown)');
        }
      }
      continue;
    }
    if (message.role === 'tool') {
      toolResults.push(String(message.content ?? '').slice(0, 500));
      continue;
    }
    if (message.role === 'meta' && message.type === 'session.resume_hint') {
      resumeHint = message;
    }
  }

  return { assistant, toolCalls, toolResults, parseErrors, resumeHint };
}

function unique(items) {
  return [...new Set(items)];
}

function tail(text, maxChars = 4000) {
  if (text.length <= maxChars) return text;
  return text.slice(text.length - maxChars);
}

function printSuccessfulRun(parsed) {
  console.log('Kimi Code run completed.');
  if (parsed.resumeHint?.session_id) {
    console.log(`Session: ${parsed.resumeHint.session_id}`);
  }
  if (parsed.resumeHint?.command) {
    console.log(`Resume: ${parsed.resumeHint.command}`);
  }
  if (parsed.toolCalls.length > 0) {
    const names = unique(parsed.toolCalls).slice(0, 12).join(', ');
    console.log(`Tool calls: ${parsed.toolCalls.length} (${names})`);
  }
  if (parsed.toolResults.length > 0) {
    console.log(`Tool results: ${parsed.toolResults.length}`);
  }
  console.log('');
  console.log('--- Kimi response ---');
  const response = parsed.assistant.join('\n\n').trim();
  console.log(response.length > 0 ? response : '(Kimi returned no assistant text.)');
  if (parsed.parseErrors.length > 0) {
    console.log('');
    console.log(`Skipped ${parsed.parseErrors.length} non-JSON stdout line(s).`);
  }
}

async function main() {
  const opts = parseArgs(process.argv.slice(2));
  const prompt = (opts.prompt ?? (await readStdin())).trim();
  if (prompt.length === 0) {
    throw new Error('Prompt is empty. Pass --prompt or pipe prompt text on stdin.');
  }

  const kimiArgs = buildKimiArgs(opts, prompt);
  if (opts.dryRun) {
    console.log(JSON.stringify({
      command: opts.kimiBin,
      args: kimiArgs.map(arg => (arg === prompt ? `<prompt:${prompt.length} chars>` : arg)),
      cwd: opts.cwd,
      timeoutSeconds: opts.timeoutSeconds,
      tee: opts.tee ?? null,
    }, null, 2));
    return;
  }

  const version = await runProcess(opts.kimiBin, ['--version'], {
    cwd: opts.cwd,
    timeoutSeconds: Math.min(opts.timeoutSeconds, 30),
  }).catch(error => {
    throw new Error(`Failed to execute ${opts.kimiBin}: ${error.message}`);
  });
  if (version.code !== 0) {
    throw new Error(
      `Kimi Code CLI preflight failed. Run \`kimi login\` after installing Kimi Code.\n${tail(version.stderr || version.stdout)}`,
    );
  }

  if (opts.tee) {
    console.error(`Live feed: tail -f ${opts.tee}`);
  }
  const result = await runProcess(opts.kimiBin, kimiArgs, {
    cwd: opts.cwd,
    timeoutSeconds: opts.timeoutSeconds,
    teePath: opts.tee,
  });
  if (result.timedOut) {
    console.error(`Kimi Code timed out after ${opts.timeoutSeconds} seconds.`);
    if (result.stderr.trim().length > 0) console.error(tail(result.stderr));
    process.exit(124);
  }
  if (result.code !== 0) {
    console.error(`Kimi Code exited with code ${result.code ?? 'null'}${result.signal ? ` signal ${result.signal}` : ''}.`);
    if (result.stderr.trim().length > 0) {
      console.error('');
      console.error('--- stderr ---');
      console.error(tail(result.stderr));
    }
    if (result.stdout.trim().length > 0) {
      console.error('');
      console.error('--- stdout ---');
      console.error(tail(result.stdout));
    }
    process.exit(result.code ?? 1);
  }

  const parsed = parseKimiStreamJson(result.stdout);
  printSuccessfulRun(parsed);
}

main().catch(error => {
  console.error(error instanceof Error ? error.message : String(error));
  process.exit(1);
});
