#!/usr/bin/env node

import { spawn } from 'node:child_process';
import { createWriteStream } from 'node:fs';
import { tmpdir } from 'node:os';
import { join as joinPath } from 'node:path';
import { stdin as processStdin } from 'node:process';

const DEFAULT_TIMEOUT_SECONDS = 1800;
const MAX_CAPTURE_CHARS = 10 * 1024 * 1024;

function usage() {
  return `Usage:
  kimi-agent-run [options] < prompt.txt
  kimi-agent-run --prompt "task" [options]

Runs Kimi Code CLI via its official non-interactive prompt mode:
  kimi -p "<task>" --output-format stream-json

Options:
  --prompt <text>             Prompt text. If omitted, stdin is used.
  --continue                  Continue the most recent Kimi session for the cwd.
  --session <id>              Resume a specific Kimi session id.
  --model <model>             Kimi model alias for this invocation.
  --worktree[=<name>]         Ask Kimi to create a git worktree for a new session.
  --cwd <path>                Working directory for the Kimi process.
  --timeout-seconds <n>       Timeout before terminating Kimi. Default: ${DEFAULT_TIMEOUT_SECONDS}.
  --kimi-bin <path>           Kimi executable. Default: kimi.
  --dry-run                   Print the resolved Kimi command without running it.
  --tee <path>                Mirror Kimi's live stream-json to <path> as it runs.
                              Watch it with: tail -f <path>
  --live                      Like --tee but to a temp file; prints the tail command.
  --verify <cmd>              Shell check run after Kimi (in --cwd). On failure,
                              Kimi is re-invoked with --continue to fix it, up to
                              --max-iters times. Exit 2 if still failing.
                              Cannot be combined with --worktree.
  --max-iters <n>             Max Kimi attempts when --verify is set. Default: 1
                              (run once, report verify status; no auto-fix loop).
                              --timeout-seconds applies per sub-process (each
                              Kimi run and each verify run), not as a total cap.
  --help                      Show this help.
`;
}

function parseArgs(argv) {
  const opts = {
    kimiBin: process.env.KIMI_AGENT_KIMI_BIN || 'kimi',
    timeoutSeconds: DEFAULT_TIMEOUT_SECONDS,
    prompt: undefined,
    continue: false,
    session: undefined,
    model: undefined,
    worktree: undefined,
    cwd: process.cwd(),
    dryRun: false,
    tee: undefined,
    live: false,
    verify: undefined,
    maxIters: 1,
  };

  for (let i = 0; i < argv.length; i += 1) {
    const arg = argv[i];
    if (arg === '--help' || arg === '-h') {
      console.log(usage());
      process.exit(0);
    }
    if (arg === '--dry-run') {
      opts.dryRun = true;
      continue;
    }
    if (arg === '--continue' || arg === '-C') {
      opts.continue = true;
      continue;
    }
    if (arg === '--prompt' || arg === '-p') {
      opts.prompt = requireValue(argv, ++i, arg);
      continue;
    }
    if (arg === '--session' || arg === '-S' || arg === '-r' || arg === '--resume') {
      opts.session = requireValue(argv, ++i, arg);
      continue;
    }
    if (arg === '--model' || arg === '-m') {
      opts.model = requireValue(argv, ++i, arg);
      continue;
    }
    if (arg === '--cwd') {
      opts.cwd = requireValue(argv, ++i, arg);
      continue;
    }
    if (arg === '--kimi-bin') {
      opts.kimiBin = requireValue(argv, ++i, arg);
      continue;
    }
    if (arg === '--tee') {
      opts.tee = requireValue(argv, ++i, arg);
      continue;
    }
    if (arg === '--live') {
      opts.live = true;
      continue;
    }
    if (arg === '--verify') {
      opts.verify = requireValue(argv, ++i, arg);
      continue;
    }
    if (arg === '--max-iters') {
      const raw = requireValue(argv, ++i, arg);
      const parsed = Number(raw);
      if (!Number.isInteger(parsed) || parsed < 1) {
        throw new Error(`Invalid --max-iters value: ${raw} (must be an integer >= 1).`);
      }
      opts.maxIters = parsed;
      continue;
    }
    if (arg === '--timeout-seconds') {
      const raw = requireValue(argv, ++i, arg);
      const parsed = Number(raw);
      if (!Number.isFinite(parsed) || parsed <= 0) {
        throw new Error(`Invalid --timeout-seconds value: ${raw}`);
      }
      opts.timeoutSeconds = parsed;
      continue;
    }
    if (arg === '--worktree' || arg === '-w') {
      const next = argv[i + 1];
      if (next !== undefined && !next.startsWith('-')) {
        opts.worktree = next;
        i += 1;
      } else {
        opts.worktree = true;
      }
      continue;
    }
    if (arg.startsWith('--worktree=')) {
      opts.worktree = arg.slice('--worktree='.length);
      continue;
    }
    throw new Error(`Unknown argument: ${arg}`);
  }

  if (opts.continue && opts.session !== undefined) {
    throw new Error('Cannot combine --continue with --session.');
  }
  if (opts.worktree !== undefined && (opts.continue || opts.session !== undefined)) {
    throw new Error('Cannot combine --worktree with --continue or --session.');
  }
  if (opts.verify !== undefined && opts.worktree !== undefined) {
    throw new Error(
      'Cannot combine --verify with --worktree: --verify runs in the working ' +
        "directory, but --worktree isolates Kimi's changes in a separate worktree.",
    );
  }
  if (opts.live && opts.tee === undefined) {
    opts.tee = joinPath(tmpdir(), `kimi-agent-${process.pid}.jsonl`);
  }
  return opts;
}

function requireValue(argv, index, flag) {
  const value = argv[index];
  if (value === undefined || value.length === 0) {
    throw new Error(`${flag} requires a value.`);
  }
  return value;
}

function readStdin() {
  return new Promise((resolve, reject) => {
    let data = '';
    processStdin.setEncoding('utf8');
    processStdin.on('data', chunk => {
      data += chunk;
    });
    processStdin.on('error', reject);
    processStdin.on('end', () => resolve(data));
  });
}

function buildKimiArgs(opts, prompt) {
  const args = [];
  if (opts.continue) args.push('--continue');
  if (opts.session !== undefined) args.push('--session', opts.session);
  if (opts.model !== undefined) args.push('--model', opts.model);
  if (opts.worktree === true) args.push('--worktree');
  if (typeof opts.worktree === 'string') args.push(`--worktree=${opts.worktree}`);
  args.push('--prompt', prompt, '--output-format', 'stream-json');
  return args;
}

function appendTailLimited(current, chunk) {
  const next = current + chunk;
  return next.length > MAX_CAPTURE_CHARS ? next.slice(next.length - MAX_CAPTURE_CHARS) : next;
}

function createKimiStreamParser() {
  const parsed = {
    assistant: [],
    toolCalls: [],
    toolResults: [],
    parseErrors: [],
    resumeHint: undefined,
  };
  let pending = '';

  function parseLine(rawLine) {
    const line = rawLine.trim();
    if (line.length === 0) return;

    let message;
    try {
      message = JSON.parse(line);
    } catch (error) {
      parsed.parseErrors.push(line.slice(0, 500));
      return;
    }

    if (message.role === 'assistant') {
      if (typeof message.content === 'string' && message.content.trim().length > 0) {
        parsed.assistant.push(message.content.trim());
      }
      if (Array.isArray(message.tool_calls)) {
        for (const call of message.tool_calls) {
          const name = call?.function?.name;
          parsed.toolCalls.push(typeof name === 'string' && name.length > 0 ? name : '(unknown)');
        }
      }
      return;
    }

    if (message.role === 'tool') {
      parsed.toolResults.push(String(message.content ?? '').slice(0, 500));
      return;
    }

    if (message.role === 'meta' && message.type === 'session.resume_hint') {
      parsed.resumeHint = message;
    }
  }

  return {
    ingest(chunk) {
      pending += chunk;
      const lines = pending.split(/\r?\n/);
      pending = lines.pop() ?? '';
      for (const line of lines) parseLine(line);
    },
    finish() {
      parseLine(pending);
      pending = '';
      return parsed;
    },
  };
}

function runProcess(command, args, opts = {}) {
  return new Promise((resolve, reject) => {
    const child = spawn(command, args, {
      cwd: opts.cwd,
      stdio: ['ignore', 'pipe', 'pipe'],
      env: process.env,
    });

    let stdout = '';
    let stderr = '';
    let timedOut = false;
    const stdoutParser = opts.parseStdout ? createKimiStreamParser() : undefined;

    let teeStream;
    if (opts.teePath) {
      // Append (not truncate) when re-invoked in the verify fix loop so each
      // attempt's stream is kept instead of clobbering the previous one; the
      // separator keeps the attempts readable. The initial run truncates.
      teeStream = createWriteStream(opts.teePath, {
        encoding: 'utf8',
        flags: opts.teeAppend ? 'a' : 'w',
      });
      teeStream.on('error', error => {
        process.stderr.write(`Live tee to ${opts.teePath} failed: ${error.message}\n`);
        teeStream = undefined;
      });
      if (opts.teeAppend && teeStream) {
        teeStream.write('\n--- kimi --continue (fix) ---\n');
      }
    }

    const timer = setTimeout(() => {
      timedOut = true;
      child.kill('SIGTERM');
      setTimeout(() => child.kill('SIGKILL'), 5000).unref();
    }, opts.timeoutSeconds * 1000);
    timer.unref();

    child.stdout.setEncoding('utf8');
    child.stderr.setEncoding('utf8');
    child.stdout.on('data', chunk => {
      stdout = appendTailLimited(stdout, chunk);
      stdoutParser?.ingest(chunk);
      if (teeStream) teeStream.write(chunk);
    });
    child.stderr.on('data', chunk => {
      stderr = appendTailLimited(stderr, chunk);
    });
    child.on('error', reject);
    child.on('close', (code, signal) => {
      clearTimeout(timer);
      if (teeStream) teeStream.end();
      resolve({ code, signal, stdout, stderr, timedOut, parsed: stdoutParser?.finish() });
    });
  });
}

function parseKimiStreamJson(stdout) {
  const parser = createKimiStreamParser();
  for (const rawLine of stdout.split(/\r?\n/)) {
    parser.ingest(`${rawLine}\n`);
  }
  return parser.finish();
}

function unique(items) {
  return [...new Set(items)];
}

function tail(text, maxChars = 4000) {
  if (text.length <= maxChars) return text;
  return text.slice(text.length - maxChars);
}

function runShell(cmd, cwd, timeoutSeconds) {
  return runProcess('sh', ['-c', cmd], { cwd, timeoutSeconds }).then(r => ({
    code: r.code,
    timedOut: r.timedOut,
    output: [r.stdout, r.stderr].filter(s => s && s.trim().length > 0).join('\n'),
  }));
}

async function gitText(cwd, args) {
  const r = await runProcess('git', args, { cwd, timeoutSeconds: 30 }).catch(() => null);
  if (r === null || r.code !== 0) return null;
  return r.stdout.replace(/\s+$/, '');
}

// #2: a git snapshot of the work directory so the caller can verify what
// actually changed (and whether Kimi committed) instead of trusting prose.
async function gitSummary(opts) {
  const inside = await gitText(opts.cwd, ['rev-parse', '--is-inside-work-tree']);
  if (inside !== 'true') return null;
  if (opts.worktree !== undefined) {
    const list = await gitText(opts.cwd, ['worktree', 'list']);
    const note =
      'Kimi was asked to work in a NEW git worktree — its changes are not in ' +
      'this directory. Inspect the worktree below.';
    return list ? `${note}\n\ngit worktree list:\n${list}` : note;
  }
  const status = await gitText(opts.cwd, ['status', '--porcelain']);
  const stat = await gitText(opts.cwd, ['--no-pager', 'diff', '--stat', 'HEAD']);
  const log = await gitText(opts.cwd, ['--no-pager', 'log', '--oneline', '-5']);
  const parts = [
    `Uncommitted changes (git status --porcelain):\n${status && status.length > 0 ? status : '(clean)'}`,
  ];
  if (stat && stat.length > 0) parts.push(`Working tree vs HEAD (git diff --stat HEAD):\n${stat}`);
  if (log) parts.push(`Recent commits (git log --oneline -5):\n${log}`);
  return parts.join('\n\n');
}

function buildContinueArgs(opts, prompt) {
  // --session is intentionally NOT re-passed: after the initial run there is a
  // "most recent session" for the cwd, so --continue resumes exactly it (and
  // Kimi rejects --session together with --continue).
  const args = ['--continue'];
  if (opts.model !== undefined) args.push('--model', opts.model);
  args.push('--prompt', prompt, '--output-format', 'stream-json');
  return args;
}

function buildFixPrompt(verifyCmd, output) {
  return [
    `The verification command \`${verifyCmd}\` is still failing after your last changes.`,
    'Fix the root cause so the command passes. Do not commit unless it succeeds.',
    '',
    'Command output (tail):',
    tail(output, 3000),
  ].join('\n');
}

// #1: run --verify in the work dir; on failure, re-invoke Kimi with
// --continue (feeding the failure back) up to --max-iters total attempts.
async function runVerifyLoop(opts) {
  let attempts = 1; // the initial Kimi run already happened
  let verify = await runShell(opts.verify, opts.cwd, opts.timeoutSeconds);
  while (verify.code !== 0 && attempts < opts.maxIters) {
    attempts += 1;
    process.stderr.write(`Verify failed; Kimi fix attempt ${attempts}/${opts.maxIters}...\n`);
    const fix = await runProcess(
      opts.kimiBin,
      buildContinueArgs(opts, buildFixPrompt(opts.verify, verify.output)),
      {
        cwd: opts.cwd,
        timeoutSeconds: opts.timeoutSeconds,
        teePath: opts.tee,
        teeAppend: true,
        parseStdout: true,
      },
    );
    if (fix.timedOut || fix.code !== 0) {
      return {
        passed: false,
        attempts,
        lastOutput: `Kimi --continue ${fix.timedOut ? 'timed out' : `exited ${fix.code}`}.\n${tail(fix.stderr || fix.stdout, 1500)}`,
      };
    }
    verify = await runShell(opts.verify, opts.cwd, opts.timeoutSeconds);
  }
  return { passed: verify.code === 0, attempts, lastOutput: verify.output };
}

function printSuccessfulRun(parsed) {
  console.log('Kimi Code run completed.');
  if (parsed.resumeHint?.session_id) {
    console.log(`Session: ${parsed.resumeHint.session_id}`);
  }
  if (parsed.resumeHint?.command) {
    console.log(`Resume: ${parsed.resumeHint.command}`);
  }
  if (parsed.toolCalls.length > 0) {
    const names = unique(parsed.toolCalls).slice(0, 12).join(', ');
    console.log(`Tool calls: ${parsed.toolCalls.length} (${names})`);
  }
  if (parsed.toolResults.length > 0) {
    console.log(`Tool results: ${parsed.toolResults.length}`);
  }
  console.log('');
  console.log('--- Kimi response ---');
  const response = parsed.assistant.join('\n\n').trim();
  console.log(response.length > 0 ? response : '(Kimi returned no assistant text.)');
  if (parsed.parseErrors.length > 0) {
    console.log('');
    console.log(`Skipped ${parsed.parseErrors.length} non-JSON stdout line(s).`);
  }
}

async function main() {
  const opts = parseArgs(process.argv.slice(2));
  const prompt = (opts.prompt ?? (await readStdin())).trim();
  if (prompt.length === 0) {
    throw new Error('Prompt is empty. Pass --prompt or pipe prompt text on stdin.');
  }

  const kimiArgs = buildKimiArgs(opts, prompt);
  if (opts.dryRun) {
    console.log(JSON.stringify({
      command: opts.kimiBin,
      args: kimiArgs.map(arg => (arg === prompt ? `<prompt:${prompt.length} chars>` : arg)),
      cwd: opts.cwd,
      timeoutSeconds: opts.timeoutSeconds,
      tee: opts.tee ?? null,
    }, null, 2));
    return;
  }

  const version = await runProcess(opts.kimiBin, ['--version'], {
    cwd: opts.cwd,
    timeoutSeconds: Math.min(opts.timeoutSeconds, 30),
  }).catch(error => {
    throw new Error(`Failed to execute ${opts.kimiBin}: ${error.message}`);
  });
  if (version.code !== 0) {
    throw new Error(
      `Kimi Code CLI preflight failed. Run \`kimi login\` after installing Kimi Code.\n${tail(version.stderr || version.stdout)}`,
    );
  }

  if (opts.tee) {
    console.error(`Live feed: tail -f ${opts.tee}`);
  }
  const result = await runProcess(opts.kimiBin, kimiArgs, {
    cwd: opts.cwd,
    timeoutSeconds: opts.timeoutSeconds,
    teePath: opts.tee,
    parseStdout: true,
  });
  if (result.timedOut) {
    console.error(`Kimi Code timed out after ${opts.timeoutSeconds} seconds.`);
    if (result.stderr.trim().length > 0) console.error(tail(result.stderr));
    process.exit(124);
  }
  if (result.code !== 0) {
    console.error(`Kimi Code exited with code ${result.code ?? 'null'}${result.signal ? ` signal ${result.signal}` : ''}.`);
    if (result.stderr.trim().length > 0) {
      console.error('');
      console.error('--- stderr ---');
      console.error(tail(result.stderr));
    }
    if (result.stdout.trim().length > 0) {
      console.error('');
      console.error('--- stdout ---');
      console.error(tail(result.stdout));
    }
    process.exit(result.code ?? 1);
  }

  const parsed = result.parsed ?? parseKimiStreamJson(result.stdout);
  printSuccessfulRun(parsed);

  let verifyOutcome;
  if (opts.verify !== undefined) {
    verifyOutcome = await runVerifyLoop(opts);
    console.log('');
    console.log(`--- verify: ${opts.verify} ---`);
    if (verifyOutcome.passed) {
      console.log(`PASS (after ${verifyOutcome.attempts} Kimi attempt(s)).`);
    } else {
      console.log(
        `FAIL (after ${verifyOutcome.attempts} Kimi attempt(s), max ${opts.maxIters}). Last output (tail):`,
      );
      console.log(tail(verifyOutcome.lastOutput, 2000));
    }
  }

  const summary = await gitSummary(opts);
  if (summary !== null) {
    console.log('');
    console.log('--- repository state ---');
    console.log(summary);
  }

  if (verifyOutcome && !verifyOutcome.passed) {
    process.exit(2);
  }
}

main().catch(error => {
  console.error(error instanceof Error ? error.message : String(error));
  process.exit(1);
});
